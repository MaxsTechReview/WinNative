<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/settings_action_surface_pressed" />
            <stroke
                android:width="1.5dp"
                android:color="@color/settings_accent"
                android:dashWidth="6dp"
                android:dashGap="4dp" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/settings_action_surface" />
            <stroke
                android:width="1.5dp"
                android:color="@color/settings_outline"
                android:dashWidth="6dp"
                android:dashGap="4dp" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
