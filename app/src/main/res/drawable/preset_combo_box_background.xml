<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:drawable="@drawable/combo_box_pressed_dark" />
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="7dp" />
                    <solid android:color="@android:color/transparent" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/settings_input_outline_soft" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_focused="true">
        <layer-list>
            <item android:drawable="@drawable/combo_box_normal_dark" />
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="7dp" />
                    <solid android:color="@android:color/transparent" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/settings_input_outline_soft" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item android:drawable="@drawable/combo_box_normal_dark" />
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="7dp" />
                    <solid android:color="@android:color/transparent" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/settings_input_outline_soft" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
