<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/settings_action_surface_pressed" />
            <stroke
                android:width="1dp"
                android:color="@color/settings_accent" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/settings_action_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/settings_outline" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
