<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/container_card_add_surface"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="12dp">

    <ImageView
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/content_icon_surface"
        android:padding="8dp"
        android:src="@drawable/ic_content_add"
        app:tint="@color/settings_accent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/inter"
        android:text="@string/new_container"
        android:textColor="@color/settings_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <View
        android:layout_width="0dp"
        android:layout_height="34dp"
        android:layout_marginTop="10dp"
        android:visibility="invisible" />

</LinearLayout>
