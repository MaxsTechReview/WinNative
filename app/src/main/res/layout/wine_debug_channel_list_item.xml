<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/TextView"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/content_status_badge_background"
        android:ellipsize="end"
        android:fontFamily="@font/inter"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:paddingHorizontal="14dp"
        android:textColor="@color/settings_text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/BTAdd"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/content_action_button_background"
        android:padding="8dp"
        android:src="@drawable/icon_add"
        android:visibility="gone"
        app:tint="@color/settings_icon_tint" />

    <ImageView
        android:id="@+id/BTReset"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/content_action_button_background"
        android:padding="8dp"
        android:src="@drawable/icon_reset"
        android:visibility="gone"
        app:tint="@color/settings_icon_tint" />

    <ImageView
        android:id="@+id/BTRemove"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="@drawable/content_action_button_background"
        android:padding="8dp"
        android:src="@drawable/icon_remove2"
        app:tint="@color/settings_icon_tint" />
</LinearLayout>
